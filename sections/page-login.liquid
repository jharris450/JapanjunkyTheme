{%- comment -%}
  JapanJunky Login Gateway — Terminal-styled auth gateway
  with portal vortex background and watchful Tsuno.
  Redirects to Shopify's hosted authentication.
{%- endcomment -%}

<script>
  window.JJ_SCREENSAVER_CONFIG = window.JJ_SCREENSAVER_CONFIG || {};
  window.JJ_SCREENSAVER_CONFIG.cameraPreset = 'login';
</script>

<div class="jj-auth" id="jj-auth">
  <div class="jj-auth__title">
    <span>Log On to {{ shop.name | upcase }}</span>
    {% render 'jj-winctl' %}
  </div>
  <div class="jj-auth__body">
    <p class="jj-auth__message">Access is restricted.</p>
    <p class="jj-auth__message">Log on to continue.</p>
  </div>
  <div class="jj-auth__actions">
    <a href="/account/login" class="jj-win95-btn-sm">[Log On]</a>
  </div>
</div>

{% schema %}
{
  "name": "Login Gateway",
  "tag": "section"
}
{% endschema %}
