{%- assign featured = section.settings.collection | default: collections['all'] -%}

{%- comment -%} THREE-COLUMN CATALOG {%- endcomment -%}
<div class="jj-catalog-layout">

  {%- comment -%} LEFT SIDEBAR {%- endcomment -%}
  <div class="jj-left-sidebar">
    {% render 'category-list', section: section %}
    {% render 'member-login-box' %}
  </div>

  {%- comment -%} CENTER: PRODUCT TABLE {%- endcomment -%}
  <div class="jj-center-content">
    <div class="jj-filter-bar" id="jj-filter-bar" style="display:none;">
      <span class="jj-filter-bar__prompt">&gt;</span>
      <span class="jj-filter-bar__tags" id="jj-filter-tags"></span>
      <button class="jj-filter-bar__clear" id="jj-filter-clear">[clear all]</button>
    </div>
    <div class="jj-product-table-wrap" id="jj-product-table-wrap">
      <table class="jj-product-table" id="jj-product-table">
        <colgroup>
          <col style="width:80px;">
          <col style="width:70px;">
          <col style="width:70px;">
          <col style="width:70px;">
          <col style="width:70px;">
          <col>
          <col style="width:84px;">
        </colgroup>
        <thead>
          <tr>
            <th></th>
            <th>CODE</th>
            <th>CAT#</th>
            <th>COND</th>
            <th>FORMAT</th>
            <th>TITLE &amp; DESCRIPTION</th>
            <th style="text-align:right;">PRICE</th>
          </tr>
        </thead>
        <tbody id="jj-product-tbody">
          {%- for product in featured.products limit: section.settings.products_to_show -%}
            {% render 'product-table-row', product: product, index: forloop.index0 %}
          {%- else -%}
            {%- for i in (1..12) -%}
              {% render 'product-table-row', product: blank, index: forloop.index0 %}
            {%- endfor -%}
          {%- endfor -%}
        </tbody>
      </table>
    </div>

    <div class="jj-table-footer">
      <div class="jj-table-footer__left">
        <span>{{ featured.products_count | default: 0 }} items</span>
        <span style="color:#444;">|</span>
        <span style="color:#555;">
          showing 1-{{ section.settings.products_to_show }}
        </span>
      </div>
      <div class="jj-table-footer__right">
        <span style="color:#666;">sort:</span>
        <select class="jj-table-sort-select" id="jj-sort-select">
          <option value="manual">Default</option>
          <option value="price-ascending">Price &#8593;</option>
          <option value="price-descending">Price &#8595;</option>
          <option value="title-ascending">Name A-Z</option>
          <option value="title-descending">Name Z-A</option>
        </select>
      </div>
    </div>
  </div>

  {%- comment -%} RIGHT SIDEBAR: ITEM DETAILS {%- endcomment -%}
  <div class="jj-right-sidebar" id="jj-detail-pane">
    {% render 'product-detail-pane' %}
  </div>

</div>

{%- comment -%} MARQUEE BAR {%- endcomment -%}
{%- if section.settings.marquee_text != blank -%}
  <div class="jj-marquee-bar">
    <span class="jj-marquee-text">{{ section.settings.marquee_text }}</span>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Homepage Body",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Featured collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 50,
      "step": 2,
      "default": 20
    },
    {
      "type": "textarea",
      "id": "marquee_text",
      "label": "Marquee scrolling text",
      "default": "★★★ JAPANJUNKY ★★★ FREE SHIPPING ON ORDERS OVER $50 ★★★ USE CODE AMBER95 FOR 10% OFF ★★★ BEST VIEWED WITH NETSCAPE NAVIGATOR 3.0 AT 800x600 ★★★"
    }
  ],
  "presets": [
    {
      "name": "Homepage Body"
    }
  ]
}
{% endschema %}
