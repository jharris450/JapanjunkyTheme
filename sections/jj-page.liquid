{%- comment -%}
  Generic content page: Win98 explorer window (win98-explorer snippet) with
  the rich-text body in the main pane. Assigned by templates/page.json —
  the default for /pages/* (about, shipping info, etc.). Rides the .jj-page
  scroll-layer; prose via japanjunky-content.css.
{%- endcomment -%}
{%- capture win_body -%}
  {%- if page.content != blank -%}
    <div class="jj-prose">{{ page.content }}</div>
  {%- endif -%}
{%- endcapture -%}
{%- assign win_desc = page.content | strip_html | truncatewords: 18 -%}
{%- assign win_path = page.handle | upcase | prepend: 'PAGES\' -%}

<div class="jj-page">
  {% render 'win98-explorer', title: page.title, body: win_body, desc: win_desc, path: win_path, icon: 'doc' %}
</div>

{% schema %}
{ "name": "Page", "tag": "section", "settings": [] }
{% endschema %}
