{% render 'win95-start-menu' %}

<footer class="jj-taskbar" role="contentinfo">
  <div class="jj-start-menu-wrapper">
    <button class="jj-start-btn" id="jj-start-btn" aria-expanded="false" aria-controls="jj-start-menu">
      <span class="jj-start-btn__cart-badge" id="jj-start-btn-cart-badge" aria-hidden="true">
        <span class="jj-start-btn__cart-pop"></span>
        <span class="jj-start-btn__cart-icon">¥</span>
      </span>
      <span class="jj-start-btn__icon">&gt;_</span>
      <span>CMD</span>
    </button>
  </div>

  <div class="jj-taskbar__divider"></div>

  <div class="jj-taskbar__tabs" id="jj-taskbar-tabs">
    {%- comment -%} Tabs managed dynamically by japanjunky-wm.js {%- endcomment -%}
  </div>

  {% render 'win95-clock' %}
</footer>

{% schema %}
{
  "name": "Win95 Footer",
  "settings": []
}
{% endschema %}
