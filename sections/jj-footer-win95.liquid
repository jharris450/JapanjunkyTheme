{% render 'win95-start-menu' %}
{% render 'win95-toolbox' %}

<footer class="jj-taskbar" role="contentinfo">
  <div class="jj-start-menu-wrapper">
    <button class="jj-start-btn{% if cart.item_count > 0 %} jj-start-btn--has-cart{% endif %}" id="jj-start-btn" aria-expanded="false" aria-controls="jj-start-menu">
      <span class="jj-start-btn__cart-badge" id="jj-start-btn-cart-badge" aria-hidden="true">
        <span class="jj-start-btn__cart-pop"></span>
        <span class="jj-start-btn__cart-icon">¥</span>
      </span>
      <span class="jj-start-btn__tsuno-slot" aria-hidden="true"></span>
      <span>START</span>
    </button>
    {%- comment -%} Tsuno head logo: sibling of the button (its overflow:hidden
        would clip the horns), mood-tinted via mask + --jj-tsuno-mood. {%- endcomment -%}
    <span class="jj-start-btn__tsuno" aria-hidden="true" style="--jj-tsuno-logo: url('{{ 'tsuno-start-logo.png' | asset_url }}')"></span>
  </div>

  <div class="jj-taskbar__divider"></div>

  <div class="jj-taskbar__tabs" id="jj-taskbar-tabs"></div>

  {%- comment -%} System tray: one Win98 well holding speaker + clock {%- endcomment -%}
  <div class="jj-tray">
    <div class="jj-tray__divider" aria-hidden="true"></div>
    {% render 'win95-volume' %}
    {% render 'win95-clock' %}
  </div>
</footer>

{% schema %}
{
  "name": "Win95 Footer",
  "settings": []
}
{% endschema %}
