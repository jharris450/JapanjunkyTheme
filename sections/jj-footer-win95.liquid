{% render 'win95-start-menu' %}

<footer class="jj-taskbar" role="contentinfo">
  <div class="jj-start-menu-wrapper">
    <button class="jj-start-btn" id="jj-start-btn" aria-expanded="false" aria-controls="jj-start-menu">
      <span class="jj-start-btn__icon">&#8862;</span>
      <span>Start</span>
    </button>
  </div>

  <div class="jj-taskbar__divider"></div>

  <div class="jj-taskbar__tabs">
    {% render 'win95-taskbar-tab', label: shop.name | append: ' - Catalog', url: '/', icon: '▶', active: true %}
    {% render 'win95-taskbar-tab', label: 'My Computer', url: '/collections/all', icon: '■' %}
  </div>

  {% render 'win95-clock' %}
</footer>

{% schema %}
{
  "name": "Win95 Footer",
  "settings": []
}
{% endschema %}
