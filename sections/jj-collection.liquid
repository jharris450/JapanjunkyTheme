{%- comment -%}
  Collection page: emits the collection's products as window.JJ_PRODUCTS,
  then renders the shared grid (japanjunky-product-grid.js, standalone mode).
{%- endcomment -%}
<div class="jj-page jj-collection">
  <header class="jj-collection__header">
    <h1 class="jj-collection__title">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div class="jj-collection__desc">{{ collection.description }}</div>
    {%- endif -%}
  </header>

  <script>
    window.JJ_PRODUCTS = [
      {% render 'jj-product-json', items: collection.products, limit: 250, include_unavailable: true %}
    ];
  </script>

  {% render 'jj-grid-bar' %}
</div>

{% schema %}
{ "name": "Collection", "settings": [] }
{% endschema %}
