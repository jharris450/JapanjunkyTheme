<header class="jj-header jj-ascii-window jj-depth-1" data-parallax-layer>
  <div class="jj-window-titlebar">
    <span class="jj-window-titlebar__title">{{ shop.name | upcase }}</span>
    <div class="jj-window-titlebar__controls">
      <span class="jj-window-titlebar__btn">в”Ђ</span>
      <span class="jj-window-titlebar__btn">в–Ў</span>
      <span class="jj-window-titlebar__btn">Г—</span>
    </div>
  </div>

  <div class="jj-window-body jj-header__body">
    <div class="jj-header__logo">
      <a href="/" class="jj-header__logo-link">
        <pre class="jj-header__ascii-logo jj-glow" aria-label="{{ shop.name }}">
     в•¦в•”в•ђв•—в•”в•ђв•—в•”в•ђв•—в•”в•—в•” в•¦в•¦ в•¦в•”в•—в•”в•¦в•”в•ђв•¦ в•¦
     в•‘в• в•ђв•Јв• в•ђв•ќв• в•ђв•Јв•‘в•‘в•‘ в•‘в•‘ в•‘в•‘в•‘в•‘в• в•©в•—в•љв•¦в•ќ
    в•љв•ќв•© в•©в•©  в•© в•©в•ќв•љв•ќв•љв•ќв•љв•ђв•ќв•ќв•љв•ќв•© в•© в•©</pre>
      </a>
    </div>

    <div class="jj-header__nav">
      <form action="/search" method="get" class="jj-header__search" role="search">
        <label for="header-search" class="jj-sr-only">{{ 'general.search' | t }}</label>
        <span class="jj-header__search-icon">{% render 'ascii-icon', icon: 'search' %}</span>
        <input
          type="search"
          id="header-search"
          name="q"
          class="jj-header__search-input"
          placeholder="{{ 'header.search_placeholder' | t }}"
          autocomplete="off"
        >
      </form>

      <div class="jj-header__actions">
        <a href="/cart" class="jj-header__action" title="{{ 'general.cart' | t }}">
          {% render 'ascii-icon', icon: 'cart' %}
          <span class="jj-header__action-label">{{ 'general.cart' | t }}</span>
          <span class="jj-header__cart-count">({{ cart.item_count }})</span>
        </a>
        <a href="/account" class="jj-header__action" title="{{ 'header.watchlist' | t }}">
          {% render 'ascii-icon', icon: 'star' %}
          <span class="jj-header__action-label">{{ 'header.watchlist' | t }}</span>
        </a>
        <a href="/checkout" class="jj-header__action" title="{{ 'header.checkout' | t }}">
          {% render 'ascii-icon', icon: 'cart' %}
          <span class="jj-header__action-label">{{ 'header.checkout' | t }}</span>
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .jj-header__body {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px;
    padding: 8px 12px;
  }

  .jj-header__logo-link {
    text-decoration: none;
    color: var(--jj-primary);
  }

  .jj-header__logo-link:hover {
    text-decoration: none;
  }

  .jj-header__ascii-logo {
    font-size: 11px;
    line-height: 1.1;
    color: var(--jj-primary);
    margin: 0;
  }

  .jj-header__nav {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .jj-header__search {
    display: flex;
    align-items: center;
    border: 2px solid;
    border-color: #808080 #dfdfdf #dfdfdf #808080;
    background: #1a1a1a;
    padding: 0 6px;
  }

  .jj-header__search-icon {
    color: var(--jj-secondary);
    font-size: 12px;
    margin-right: 4px;
  }

  .jj-header__search-input {
    background: transparent;
    border: none;
    color: var(--jj-text);
    font-family: inherit;
    font-size: 12px;
    padding: 4px;
    width: 180px;
    outline: none;
  }

  .jj-header__actions {
    display: flex;
    gap: 12px;
  }

  .jj-header__action {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: var(--jj-text);
    text-decoration: none;
    white-space: nowrap;
  }

  .jj-header__action:hover {
    color: var(--jj-secondary);
    text-decoration: none;
  }

  .jj-header__cart-count {
    color: var(--jj-primary);
    font-size: 11px;
  }

  @media (max-width: 768px) {
    .jj-header__body {
      flex-direction: column;
      align-items: stretch;
    }
    .jj-header__search-input {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
