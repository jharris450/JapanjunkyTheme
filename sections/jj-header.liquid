{%- comment -%} NAV BAR {%- endcomment -%}
<div class="jj-nav-bar">
  <span class="jj-nav-bar__icon">&#9658;</span>
  <span class="jj-nav-bar__label">Search</span>
  <span class="jj-nav-bar__sep">&#8250;</span>
  <form action="/search" method="get" style="flex:1;display:flex;">
    <input type="search" name="q" class="jj-nav-bar__input" placeholder="Search catalog..." autocomplete="off">
  </form>
  <div class="jj-nav-bar__actions">
    <a href="/checkout" class="jj-nav-action-btn">&#9632; Checkout</a>
    <a href="/account" class="jj-nav-action-btn">&#9734; Watchlist</a>
    <a href="/cart" class="jj-nav-action-btn">&#9632; Cart ({{ cart.item_count }})</a>
  </div>
</div>

{%- comment -%} STORE HEADER {%- endcomment -%}
<div class="jj-store-header">
  <div class="jj-store-header__left">
    <div class="jj-store-header__logo">
      <a href="/">
        <pre aria-label="{{ shop.name }}">
 ╦╔═╗╔═╗╔═╗╔╗╔ ╦╦ ╦╔╗╔╦╔═╦ ╦
 ║╠═╣╠═╝╠═╣║║║ ║║ ║║║║╠╩╗╚╦╝
╚╝╩ ╩╩  ╩ ╩╝╚╝╚╝╚═╝╝╚╝╩ ╩ ╩</pre>
      </a>
    </div>
  </div>
  <div class="jj-store-header__right">
    <span class="jj-sys-status__rule"></span>
    <div class="jj-sys-status">
      <div class="jj-sys-status__line"><span class="jj-sys-dot jj-sys-dot--online"></span>SYS.ONLINE</div>
      <div class="jj-sys-status__line"><span class="jj-sys-dot jj-sys-dot--connected"></span>CONN.SECURE</div>
      <div class="jj-sys-status__line"><span class="jj-sys-dot jj-sys-dot--idle"></span>{{ collections['all'].products_count | default: 0 }} ITEMS</div>
    </div>
  </div>
</div>

<hr class="jj-hr-fancy">

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
