{%- comment -%} TERMINAL TITLE BAR {%- endcomment -%}
<div class="jj-nav-bar">
  <span class="jj-nav-bar__icon jj-glow--green">&gt;_</span>
  <span class="jj-nav-bar__label">JAPANJUNKY — Catalog</span>
  <form action="/search" method="get" style="flex:1;display:flex;">
    <input type="search" name="q" class="jj-nav-bar__input" placeholder="search query..." autocomplete="off">
  </form>
  <div class="jj-nav-bar__actions">
    <a href="/checkout" class="jj-nav-action-btn">[Checkout]</a>
    <a href="/account" class="jj-nav-action-btn">[Watchlist]</a>
    <a href="/cart" class="jj-nav-action-btn">[Cart:{{ cart.item_count }}]</a>
  </div>
</div>

{%- comment -%} STORE HEADER {%- endcomment -%}
<div class="jj-store-header">
  <div class="jj-store-header__left">
    <div class="jj-store-header__logo">
      <a href="/">
        <img
          src="{{ 'japanjunky-logo.png' | asset_url }}"
          alt="{{ shop.name }}"
          class="jj-logo-img"
          width="592"
          height="96"
        >
      </a>
    </div>
  </div>
</div>

<hr class="jj-hr-fancy">

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
