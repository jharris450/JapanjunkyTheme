<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="view-transition" content="same-origin">

  <title>{{ page_title }}{% unless page_title contains shop.name %} - {{ shop.name }}{% endunless %}</title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {{ content_for_header }}

  <style>
    :root {
      --jj-bg: {{ settings.color_background }};
      --jj-primary: {{ settings.color_primary }};
      --jj-secondary: {{ settings.color_secondary }};
      --jj-accent: {{ settings.color_accent }};
      --jj-text: {{ settings.color_text }};
      --jj-win95-bar: {{ settings.color_win95_bar }};
      --jj-parallax-intensity: {{ settings.parallax_intensity }}px;
    }
  </style>

  {{ 'japanjunky-base.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-crt.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-ascii.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-win95.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-ring-carousel.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-product-grid.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-product-info.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-tsuno-bubble.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-cart-page.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-calendar.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-transitions.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-product-page.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-content.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-watchlist.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-scrollbar.css' | asset_url | stylesheet_tag }}
  {% if settings.splash_enabled %}
  {{ 'japanjunky-splash.css' | asset_url | stylesheet_tag }}
  {% endif %}
  {% if template.suffix == 'login' %}
  {{ 'japanjunky-auth.css' | asset_url | stylesheet_tag }}
  {% endif %}

  <script>
