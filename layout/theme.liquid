          {{ 'cursor-arrow-0.png' | asset_url | json }},
          {{ 'cursor-arrow-1.png' | asset_url | json }},
          {{ 'cursor-arrow-2.png' | asset_url | json }},
          {{ 'cursor-arrow-3.png' | asset_url | json }}
        ],
        hand: [
          {{ 'cursor-hand-0.png' | asset_url | json }},
          {{ 'cursor-hand-1.png' | asset_url | json }},
          {{ 'cursor-hand-2.png' | asset_url | json }},
          {{ 'cursor-hand-3.png' | asset_url | json }}
        ],
        text: [
          {{ 'cursor-text-0.png' | asset_url | json }},
          {{ 'cursor-text-1.png' | asset_url | json }},
          {{ 'cursor-text-2.png' | asset_url | json }},
          {{ 'cursor-text-3.png' | asset_url | json }}
        ],
        wait: [
          {{ 'cursor-wait-0.png' | asset_url | json }},
          {{ 'cursor-wait-1.png' | asset_url | json }},
          {{ 'cursor-wait-2.png' | asset_url | json }},
          {{ 'cursor-wait-3.png' | asset_url | json }}
        ],
        hotspots: { arrow: [0,0], hand: [3,0], text: [3,8], wait: [5,6] }
      },
      hi: {
        arrow: [
          {{ 'cursor-arrow-0-hi.png' | asset_url | json }},
          {{ 'cursor-arrow-1-hi.png' | asset_url | json }},
          {{ 'cursor-arrow-2-hi.png' | asset_url | json }},
          {{ 'cursor-arrow-3-hi.png' | asset_url | json }}
        ],
        hand: [
          {{ 'cursor-hand-0-hi.png' | asset_url | json }},
          {{ 'cursor-hand-1-hi.png' | asset_url | json }},
          {{ 'cursor-hand-2-hi.png' | asset_url | json }},
          {{ 'cursor-hand-3-hi.png' | asset_url | json }}
        ],
        text: [
          {{ 'cursor-text-0-hi.png' | asset_url | json }},
          {{ 'cursor-text-1-hi.png' | asset_url | json }},
          {{ 'cursor-text-2-hi.png' | asset_url | json }},
          {{ 'cursor-text-3-hi.png' | asset_url | json }}
        ],
        wait: [
          {{ 'cursor-wait-0-hi.png' | asset_url | json }},
          {{ 'cursor-wait-1-hi.png' | asset_url | json }},
          {{ 'cursor-wait-2-hi.png' | asset_url | json }},
          {{ 'cursor-wait-3-hi.png' | asset_url | json }}
        ],
        hotspots: { arrow: [0,0], hand: [5,0], text: [5,12], wait: [8,9] }
      },
      hh: {
        arrow: [
          {{ 'cursor-arrow-0-hh.png' | asset_url | json }},
          {{ 'cursor-arrow-1-hh.png' | asset_url | json }},
          {{ 'cursor-arrow-2-hh.png' | asset_url | json }},
          {{ 'cursor-arrow-3-hh.png' | asset_url | json }}
        ],
        hand: [
          {{ 'cursor-hand-0-hh.png' | asset_url | json }},
          {{ 'cursor-hand-1-hh.png' | asset_url | json }},
          {{ 'cursor-hand-2-hh.png' | asset_url | json }},
          {{ 'cursor-hand-3-hh.png' | asset_url | json }}
        ],
        text: [
          {{ 'cursor-text-0-hh.png' | asset_url | json }},
          {{ 'cursor-text-1-hh.png' | asset_url | json }},
          {{ 'cursor-text-2-hh.png' | asset_url | json }},
          {{ 'cursor-text-3-hh.png' | asset_url | json }}
        ],
        wait: [
          {{ 'cursor-wait-0-hh.png' | asset_url | json }},
          {{ 'cursor-wait-1-hh.png' | asset_url | json }},
          {{ 'cursor-wait-2-hh.png' | asset_url | json }},
          {{ 'cursor-wait-3-hh.png' | asset_url | json }}
        ],
        hotspots: { arrow: [0,0], hand: [8,0], text: [8,20], wait: [13,15] }
      }
    };
  </script>
</head>

<body class="jj-body{% if template == 'product' %} jj-body--product{% endif %}{% if template.suffix == 'login' %} jj-body--auth{% endif %} jj-body--scene-{{ settings.scene_mode | default: 'forest' }}">
{%- comment -%}
  Barrel-filter target. The CRT barrel is a root reference-filter; an <iframe>
  injected under the filtered element (the YouTube audio player) silently drops
  it in Chromium. So all visible UI lives in this wrapper and the filter is
  applied here, while the JS-appended YouTube host (#jj-yt-host) is added to
  <body> — OUTSIDE this wrapper — so it can never break the filter. The site is
  app-like (html/body overflow:hidden, no document scroll), so a fixed,
  viewport-sized wrapper keeps position:fixed descendants correct.
{%- endcomment -%}
<div id="jj-crt-content">
{% if settings.splash_enabled and template == 'index' %}
<canvas id="jj-splash" aria-hidden="true" tabindex="-1" style="display:none;"></canvas>
<button id="jj-splash-enter" class="jj-splash-enter" aria-label="Enter site" style="display:none;">[ENTER]</button>
<div id="jj-homepage" style="opacity:0;">
<script>try{if(sessionStorage.getItem('jj-entered')){document.getElementById('jj-homepage').style.opacity='';}}catch(e){}</script>
{% endif %}

<canvas id="jj-screensaver" aria-hidden="true" tabindex="-1" style="
  position:fixed;top:0;left:0;width:40vw;height:40vh;
  z-index:0;image-rendering:pixelated;image-rendering:crisp-edges;
  pointer-events:none;
"></canvas>

{%- comment -%} Drifting spinner/kana glyph particles over the scene {%- endcomment -%}
<canvas id="jj-glyph-field" aria-hidden="true" tabindex="-1" style="
  position:fixed;inset:0;width:100%;height:100%;
  z-index:1;pointer-events:none;
"></canvas>

  {%- comment -%} CRT overlay: aperture grille + scanlines above all UI {%- endcomment -%}
  <div class="jj-crt-overlay" aria-hidden="true"></div>

  {% if template == 'index' %}
  {%- comment -%} Left zone: product viewer + info (homepage only) {%- endcomment -%}
  <div class="jj-product-zone" id="jj-product-zone">
    <div class="jj-product-info" id="jj-product-info" style="display:none;">
      {%- comment -%} Canvas lives inside the box so its stacking context is local — lets the graphic paint in front of the box bg while keeping actions on top of the graphic. {%- endcomment -%}
      <canvas id="jj-viewer-canvas" aria-label="3D product viewer"></canvas>
      <div class="jj-product-info__artist" id="jj-pi-artist"></div>
      <div class="jj-product-info__jp-name" id="jj-pi-jp-name"></div>
      <div class="jj-product-info__title" id="jj-pi-title"></div>
      <div class="jj-product-info__jp-title" id="jj-pi-jp-title"></div>
      <div class="jj-product-info__meta" id="jj-pi-meta"></div>
      <div class="jj-product-info__price" id="jj-pi-price"></div>
      <div class="jj-product-info__actions" id="jj-pi-actions">
        <button class="jj-action-btn" id="jj-pi-add-to-cart" disabled>[Add to Cart]</button>
        <a class="jj-action-btn" id="jj-pi-view" href="#" style="display:none;">[View]</a>
        <input type="hidden" id="jj-pi-variant-id" value="">
      </div>
    </div>
    {%- comment -%} Tsuno Daishi greeting bubble {%- endcomment -%}
    <div id="jj-tsuno-bubble" class="jj-tsuno-bubble" aria-hidden="true"
         data-audio-src="{{ 'tsunogreetings.mp3' | asset_url }}">
      <span class="jj-tsuno-bubble__text"></span>
    </div>
  </div>

  {%- comment -%} Ring carousel: featured picks arc {%- endcomment -%}
  <div class="jj-ring" id="jj-ring" role="listbox" aria-roledescription="carousel" aria-label="Featured products">
    <div class="jj-ring__stage" id="jj-ring-stage"></div>
  </div>

  {%- comment -%} Scroll wrapper: screen 1 = scene/ring hero, screen 2 = product grid {%- endcomment -%}
  <div class="jj-scroll" id="jj-scroll">
    <div class="jj-scroll__screen jj-scroll__screen--hero">
      <button class="jj-scroll__indicator" id="jj-scroll-indicator" type="button" aria-label="Scroll to catalog">&#9660; CATALOG</button>
    </div>
    <div class="jj-scroll__screen jj-scroll__screen--grid">
      {% render 'jj-grid-bar' %}
    </div>
  </div>
  {% endif %}

  {%- comment -%} Shopify content_for_layout — homepage outputs JJ_PRODUCTS JSON, other pages render normally {%- endcomment -%}
  <main id="MainContent" role="main"{% if template == 'index' %} style="display:none;"{% endif %}>
    {%- comment -%} Shop policies (/policies/*) can't take a section/template — wrap
        their render in the .jj-page scroll-layer + prose so they sit above the
        scene and read as CRT, like the other content pages. {%- endcomment -%}
    {%- if template == 'policy' -%}
      <div class="jj-page jj-content">
        <header class="jj-content__header">
          <span class="jj-content__prompt">C:\&gt;</span>
          <h1 class="jj-content__title">{{ page_title }}</h1>
        </header>
        <div class="jj-prose">{{ content_for_layout }}</div>
      </div>
    {%- else -%}
      {{ content_for_layout }}
    {%- endif -%}
  </main>

  {%- comment -%} Taskbar (fixed at bottom) {%- endcomment -%}
  {% sections 'footer-group' %}

{% if settings.splash_enabled and template == 'index' %}
</div>
{% endif %}

  {% if settings.splash_enabled %}
  <script>
    {% if template == 'index' %}
    try {
      if (!sessionStorage.getItem('jj-entered')) {
        window.JJ_SPLASH_ACTIVE = true;
        window.JJ_SPLASH_CONFIG = {
          ghostTexture: {{ 'tsuno-daishi.jpg' | asset_url | json }},
          swirlSpeed: '{{ settings.screensaver_orbit_speed | default: "slow" }}',
          resolution: {{ settings.screensaver_resolution | default: 240 }},
          fps: {{ settings.screensaver_fps | default: 24 }}
        };
      }
    } catch (e) {}
    {% endif %}
  </script>
  {% endif %}

  <script>
    window.JJ_SCREENSAVER_CONFIG = {
      enabled: {{ settings.screensaver_enabled | default: true }},
      resolution: {{ settings.screensaver_resolution | default: 240 }},
      fps: {{ settings.screensaver_fps | default: 24 }},
      orbitSpeed: '{{ settings.screensaver_orbit_speed | default: "slow" }}',
      mouseInteraction: {{ settings.screensaver_mouse | default: true }},
      sceneMode: '{{ settings.scene_mode | default: "forest" }}',
      audioEnabled: {{ settings.audio_enabled | default: true }},
      {%- if template == 'product' -%}cameraPreset: 'product',{%- endif %}
      {%- if template.suffix == 'login' -%}cameraPreset: 'login',{%- endif %}
      {%- comment -%} Storefront pages: Tsuno awake + moving (no hero scroll to wake him). {%- endcomment -%}
      tsunoActive: {% unless template == 'index' or template == 'product' or template.suffix == 'login' %}true{% else %}false{% endunless %},
      ghostTexture: {{ 'tsuno-daishi.jpg' | asset_url | json }},
      risingSun: {{ 'risingsun.png' | asset_url | json }},
      guyTexture: {{ 'guy.png' | asset_url | json }}
    };
  </script>
  <script src="{{ 'three.min.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-screensaver-post.js' | asset_url }}" defer></script>
  {% if settings.scene_mode != 'portal' %}
  <script src="{{ 'japanjunky-forest.js' | asset_url }}" defer></script>
  {% endif %}
  <script src="{{ 'japanjunky-wax-sim.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-wax-shader.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-screensaver.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-glyph-field.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-guy.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-cursor-light.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-dither.js' | asset_url }}" defer></script>
  {%- comment -%} Watchlist state for JS-rendered grid stars (ids the customer already watches + login flag). {%- endcomment -%}
  <script>
    window.JJ_LOGGED_IN = {% if customer %}true{% else %}false{% endif %};
    window.JJ_WATCHLIST = [{% if customer %}{% for wp in customer.metafields.custom.watchlist.value %}{{ wp.id }}{% unless forloop.last %},{% endunless %}{% endfor %}{% endif %}];
  </script>
  {% unless template == 'product' or template.suffix == 'login' %}
  <script src="{{ 'japanjunky-ring-carousel.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-product-grid.js' | asset_url }}" defer></script>
  {% endunless %}
  <script src="{{ 'japanjunky-product-viewer.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-watchlist.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-volume.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-tsuno-bubble.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-win95-menu.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-win95-volume.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-toolbox.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-player-physics.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-player-eject.js' | asset_url }}" defer></script>
  <script>
    window.JJ_CASSETTE_TEX = {
      'cassette-front.png': "{{ 'cassette-front.png' | asset_url }}",
      'cassette-back.png': "{{ 'cassette-back.png' | asset_url }}",
      'cassette-left.png': "{{ 'cassette-left.png' | asset_url }}",
      'cassette-right.png': "{{ 'cassette-right.png' | asset_url }}",
      'cassette-top.png': "{{ 'cassette-top.png' | asset_url }}",
      'cassette-deck.png': "{{ 'cassette-deck.png' | asset_url }}",
      'cassette-lid-inner.png': "{{ 'cassette-lid-inner.png' | asset_url }}"
    };
  </script>
  <script src="{{ 'japanjunky-cassette-math.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-cassette-model.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-player.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-media-format.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-media-drag.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-audio-util.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-audio-react.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-player-audio.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-holidays.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-crt-shader.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-scrollbar.js' | asset_url }}" defer></script>
  {% if settings.parallax_enabled %}
  <script>
    window.JJ_PARALLAX_CONFIG = {
      enabled: true,
      intensity: {{ settings.parallax_intensity | default: 6 }}
    };
  </script>
  <script src="{{ 'japanjunky-parallax.js' | asset_url }}" defer></script>
  {% endif %}
  <script src="{{ 'japanjunky-calendar.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-cart.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-cart-page.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-product-page.js' | asset_url }}" defer></script>
  {% if settings.splash_enabled %}
  <script src="{{ 'japanjunky-splash.js' | asset_url }}" defer></script>
  {% endif %}
{%- comment -%} CRT Shader: Three.js overlay canvas {%- endcomment -%}
<canvas id="jj-crt-shader-canvas" aria-hidden="true" role="presentation" style="
  position:fixed;inset:0;width:100%;height:100%;
  z-index:10002;pointer-events:none;
"></canvas>
</div><!-- /#jj-crt-content -->
</body>
</html>
