<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>{{ page_title }}{% unless page_title contains shop.name %} - {{ shop.name }}{% endunless %}</title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {{ content_for_header }}

  <style>
    :root {
      --jj-bg: {{ settings.color_background }};
      --jj-primary: {{ settings.color_primary }};
      --jj-secondary: {{ settings.color_secondary }};
      --jj-accent: {{ settings.color_accent }};
      --jj-text: {{ settings.color_text }};
      --jj-win95-bar: {{ settings.color_win95_bar }};
      --jj-parallax-intensity: {{ settings.parallax_intensity }}px;
    }
  </style>

  {{ 'japanjunky-base.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-crt.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-ascii.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-win95.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-homepage.css' | asset_url | stylesheet_tag }}
  {{ 'japanjunky-calendar.css' | asset_url | stylesheet_tag }}

  <script>
    window.JJ_CURSOR_SETS = {
      std: {
        arrow: [
          {{ 'cursor-arrow-0.png' | asset_url | json }},
          {{ 'cursor-arrow-1.png' | asset_url | json }},
          {{ 'cursor-arrow-2.png' | asset_url | json }},
          {{ 'cursor-arrow-3.png' | asset_url | json }}
        ],
        hand: [
          {{ 'cursor-hand-0.png' | asset_url | json }},
          {{ 'cursor-hand-1.png' | asset_url | json }},
          {{ 'cursor-hand-2.png' | asset_url | json }},
          {{ 'cursor-hand-3.png' | asset_url | json }}
        ],
        text: [
          {{ 'cursor-text-0.png' | asset_url | json }},
          {{ 'cursor-text-1.png' | asset_url | json }},
          {{ 'cursor-text-2.png' | asset_url | json }},
          {{ 'cursor-text-3.png' | asset_url | json }}
        ],
        wait: [
          {{ 'cursor-wait-0.png' | asset_url | json }},
          {{ 'cursor-wait-1.png' | asset_url | json }},
          {{ 'cursor-wait-2.png' | asset_url | json }},
          {{ 'cursor-wait-3.png' | asset_url | json }}
        ],
        hotspots: { arrow: [0,0], hand: [3,0], text: [3,8], wait: [5,6] }
      },
      hi: {
        arrow: [
          {{ 'cursor-arrow-0-hi.png' | asset_url | json }},
          {{ 'cursor-arrow-1-hi.png' | asset_url | json }},
          {{ 'cursor-arrow-2-hi.png' | asset_url | json }},
          {{ 'cursor-arrow-3-hi.png' | asset_url | json }}
        ],
        hand: [
          {{ 'cursor-hand-0-hi.png' | asset_url | json }},
          {{ 'cursor-hand-1-hi.png' | asset_url | json }},
          {{ 'cursor-hand-2-hi.png' | asset_url | json }},
          {{ 'cursor-hand-3-hi.png' | asset_url | json }}
        ],
        text: [
          {{ 'cursor-text-0-hi.png' | asset_url | json }},
          {{ 'cursor-text-1-hi.png' | asset_url | json }},
          {{ 'cursor-text-2-hi.png' | asset_url | json }},
          {{ 'cursor-text-3-hi.png' | asset_url | json }}
        ],
        wait: [
          {{ 'cursor-wait-0-hi.png' | asset_url | json }},
          {{ 'cursor-wait-1-hi.png' | asset_url | json }},
          {{ 'cursor-wait-2-hi.png' | asset_url | json }},
          {{ 'cursor-wait-3-hi.png' | asset_url | json }}
        ],
        hotspots: { arrow: [0,0], hand: [5,0], text: [5,12], wait: [8,9] }
      },
      hh: {
        arrow: [
          {{ 'cursor-arrow-0-hh.png' | asset_url | json }},
          {{ 'cursor-arrow-1-hh.png' | asset_url | json }},
          {{ 'cursor-arrow-2-hh.png' | asset_url | json }},
          {{ 'cursor-arrow-3-hh.png' | asset_url | json }}
        ],
        hand: [
          {{ 'cursor-hand-0-hh.png' | asset_url | json }},
          {{ 'cursor-hand-1-hh.png' | asset_url | json }},
          {{ 'cursor-hand-2-hh.png' | asset_url | json }},
          {{ 'cursor-hand-3-hh.png' | asset_url | json }}
        ],
        text: [
          {{ 'cursor-text-0-hh.png' | asset_url | json }},
          {{ 'cursor-text-1-hh.png' | asset_url | json }},
          {{ 'cursor-text-2-hh.png' | asset_url | json }},
          {{ 'cursor-text-3-hh.png' | asset_url | json }}
        ],
        wait: [
          {{ 'cursor-wait-0-hh.png' | asset_url | json }},
          {{ 'cursor-wait-1-hh.png' | asset_url | json }},
          {{ 'cursor-wait-2-hh.png' | asset_url | json }},
          {{ 'cursor-wait-3-hh.png' | asset_url | json }}
        ],
        hotspots: { arrow: [0,0], hand: [8,0], text: [8,20], wait: [13,15] }
      }
    };
  </script>
  {% if settings.parallax_enabled %}
    <script>
      window.JJ_PARALLAX_CONFIG = {
        enabled: true,
        intensity: {{ settings.parallax_intensity }}
      };
    </script>
  {% endif %}
</head>

<body class="jj-body">
<canvas id="jj-screensaver" aria-hidden="true" tabindex="-1" style="
  position:fixed;top:0;left:0;width:100vw;height:100vh;
  z-index:0;image-rendering:pixelated;image-rendering:crisp-edges;
  pointer-events:none;
"></canvas>
  <div class="jj-page-wrapper jj-crt-frame jj-crt-on">
    {% sections 'header-group' %}

    <main id="MainContent" class="jj-main" role="main">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}
  </div>

  {%- if request.page_type == 'index' -%}
  <script>
    window.JJ_SCREENSAVER_CONFIG = {
      enabled: {{ settings.screensaver_enabled | default: true }},
      resolution: {{ settings.screensaver_resolution | default: 240 }},
      fps: {{ settings.screensaver_fps | default: 24 }},
      orbitSpeed: '{{ settings.screensaver_orbit_speed | default: "slow" }}',
      mouseInteraction: {{ settings.screensaver_mouse | default: true }},
      textures: []
    };
  </script>
  <script src="{{ 'three.min.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-screensaver-post.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-screensaver.js' | asset_url }}" defer></script>
  {%- endif -%}
  <script src="{{ 'japanjunky-cursor-light.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-dither.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-parallax.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-product-select.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-filter.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-search.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-win95-menu.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-holidays.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-calendar.js' | asset_url }}" defer></script>
</body>
</html>
