  <script src="{{ 'japanjunky-wax-shader.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-screensaver.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-glyph-field.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-guy.js' | asset_url }}" defer></script>
  <script src="{{ 'japanjunky-cursor-light.js' | asset_url }}" defer></script>
