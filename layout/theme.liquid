      tsunoActive: {% unless template == 'index' or template == 'product' or template.suffix == 'login' %}true{% else %}false{% endunless %},
      ghostTexture: {{ 'tsuno-daishi.jpg' | asset_url | json }},
      risingSun: {{ 'risingsun.png' | asset_url | json }},
      guyTexture: {{ 'guy.png' | asset_url | json }}
