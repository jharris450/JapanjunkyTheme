{%- comment -%}
  Win95-style Start menu with cascading submenus.
{%- endcomment -%}

<div class="jj-start-menu" id="jj-start-menu" role="menu" aria-label="Start menu">
  <div class="jj-start-menu__sidebar">JAPANJUNKY</div>

  <div class="jj-start-menu__items">
    <div class="jj-start-menu__item jj-start-menu__item--has-submenu" role="menuitem">
      {% render 'ascii-icon', icon: 'folder' %} {{ 'footer.collections' | t }}
      <div class="jj-start-submenu" role="menu">
        <a href="/collections/all" class="jj-start-submenu__item" role="menuitem">{{ 'categories.all' | t }}</a>
        {%- for collection in collections limit: 8 -%}
          {%- if collection.handle != 'all' and collection.handle != 'frontpage' -%}
            <a href="{{ collection.url }}" class="jj-start-submenu__item" role="menuitem">{{ collection.title }}</a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <a href="/search" class="jj-start-menu__item" role="menuitem">
      {% render 'ascii-icon', icon: 'search' %} {{ 'general.search' | t }}
    </a>

    <a href="/cart" class="jj-start-menu__item" role="menuitem">
      {% render 'ascii-icon', icon: 'cart' %} {{ 'general.cart' | t }} ({{ cart.item_count }})
    </a>

    <div class="jj-start-menu__divider"></div>

    <div class="jj-start-menu__item jj-start-menu__item--has-submenu" role="menuitem">
      {% render 'ascii-icon', icon: 'folder' %} {{ 'footer.policies' | t }}
      <div class="jj-start-submenu" role="menu">
        <a href="/policies/shipping-policy" class="jj-start-submenu__item" role="menuitem">{{ 'footer.shipping' | t }}</a>
        <a href="/policies/refund-policy" class="jj-start-submenu__item" role="menuitem">{{ 'footer.returns' | t }}</a>
        <a href="/policies/privacy-policy" class="jj-start-submenu__item" role="menuitem">{{ 'footer.privacy' | t }}</a>
        <a href="/policies/terms-of-service" class="jj-start-submenu__item" role="menuitem">{{ 'footer.terms' | t }}</a>
      </div>
    </div>

    <div class="jj-start-menu__divider"></div>

    {%- if customer -%}
      <a href="/account" class="jj-start-menu__item" role="menuitem">
        {% render 'ascii-icon', icon: 'user' %} {{ 'customer.account' | t }}
      </a>
      <a href="/account/logout" class="jj-start-menu__item" role="menuitem">
        {% render 'ascii-icon', icon: 'power' %} {{ 'customer.logout' | t }}
      </a>
    {%- else -%}
      <a href="/account/login" class="jj-start-menu__item" role="menuitem">
        {% render 'ascii-icon', icon: 'user' %} {{ 'customer.login' | t }}
      </a>
    {%- endif -%}
  </div>
</div>
