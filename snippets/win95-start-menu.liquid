{%- comment -%}
  Terminal-style command menu (Start menu).
{%- endcomment -%}

<div class="jj-start-menu" id="jj-start-menu" role="menu" aria-label="Command menu">
  <div class="jj-start-menu__sidebar">JAPANJUNKY</div>

  <div class="jj-start-menu__items">
    {%- comment -%} My Account {%- endcomment -%}
    <div class="jj-start-menu__section-title">-- account --</div>
    {%- comment -%}
      New customer accounts: /account is the Shopify-hosted dashboard (profile +
      orders together). There is no separate /account/register (passwordless —
      first login creates the account) or stable /account/orders path, so both
      labels point at /account to avoid dead links.
    {%- endcomment -%}
    {%- if customer -%}
      <a href="/account" class="jj-start-menu__item" role="menuitem">
        <span class="jj-start-item-icon">&gt;</span>
        <span>profile</span>
      </a>
      <a href="/account" class="jj-start-menu__item" role="menuitem">
        <span class="jj-start-item-icon">&gt;</span>
        <span>orders</span>
      </a>
    {%- else -%}
      <a href="/account/login" class="jj-start-menu__item" role="menuitem">
        <span class="jj-start-item-icon">&gt;</span>
        <span>login</span>
      </a>
    {%- endif -%}
    <a href="/pages/watchlist" class="jj-start-menu__item" role="menuitem">
      <span class="jj-start-item-icon">&gt;</span>
      <span>watchlist</span>
    </a>
    <a href="/cart" class="jj-start-menu__item" role="menuitem">
      <span class="jj-start-item-icon">&gt;</span>
      <span><span class="jj-start-menu__cart-symbol" aria-hidden="true">¥</span>cart (<span id="jj-nav-cart-count">{{ cart.item_count }}</span>)</span>
    </a>

    <div class="jj-start-menu__divider"></div>

    {%- comment -%} Site Pages {%- endcomment -%}
    <div class="jj-start-menu__section-title">-- navigate --</div>
    <a href="/" class="jj-start-menu__item" role="menuitem">
      <span class="jj-start-item-icon">&gt;</span>
      <span>home</span>
    </a>
    <a href="/collections/all?sort=newest" class="jj-start-menu__item" role="menuitem">
      <span class="jj-start-item-icon">&gt;</span>
      <span>new arrivals</span>
    </a>
    <a href="/pages/about" class="jj-start-menu__item" role="menuitem">
      <span class="jj-start-item-icon">&gt;</span>
      <span>about</span>
    </a>
    <a href="/pages/faq" class="jj-start-menu__item" role="menuitem">
      <span class="jj-start-item-icon">&gt;</span>
      <span>help</span>
    </a>
    <a href="/pages/contact" class="jj-start-menu__item" role="menuitem">
      <span class="jj-start-item-icon">&gt;</span>
      <span>contact</span>
    </a>

    <div class="jj-start-menu__divider"></div>

    {%- if customer -%}
      <a href="/account/logout" class="jj-start-menu__item" role="menuitem">
        <span class="jj-start-item-icon">&gt;</span>
        <span>logout</span>
      </a>
    {%- endif -%}
    <button type="button" class="jj-start-menu__item" id="jj-shutdown-trigger" role="menuitem">
      <span class="jj-start-item-icon">&gt;</span>
      <span>shutdown</span>
    </button>
  </div>
</div>

{%- comment -%} Shutdown dialog — Win95-style confirm + countdown {%- endcomment -%}
<div class="jj-shutdown" id="jj-shutdown" role="dialog" aria-modal="true" aria-labelledby="jj-shutdown-title" hidden>
  <div class="jj-shutdown__window" role="document">
    <div class="jj-shutdown__titlebar">
      <span class="jj-shutdown__title" id="jj-shutdown-title">Shut Down</span>
      <button type="button" class="jj-shutdown__x" id="jj-shutdown-x" aria-label="Cancel shutdown">&times;</button>
    </div>
    <div class="jj-shutdown__body">
      <p class="jj-shutdown__msg">Shutting down system<span class="jj-shutdown__dots">...</span></p>
      <p class="jj-shutdown__count">Shutting down in <span id="jj-shutdown-count">5</span></p>
      <button type="button" class="jj-shutdown__cancel jj-action-btn" id="jj-shutdown-cancel">[CANCEL]</button>
    </div>
  </div>
  <pre class="jj-shutdown__boot" id="jj-shutdown-boot" aria-hidden="true"></pre>
</div>
