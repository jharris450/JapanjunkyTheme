{%- comment -%}
  Star-only watchlist toggle (symbol, no text). Pass `product` and optional
  `corner` ('tl' | 'tr'). Initial state from the customer's custom.watchlist
  metafield; clicks handled by japanjunky-watchlist.js. Guests route to login.
{%- endcomment -%}
{%- assign is_watched = false -%}
{%- if customer -%}
  {%- for wp in customer.metafields.custom.watchlist.value -%}
    {%- if wp.id == product.id -%}{%- assign is_watched = true -%}{%- break -%}{%- endif -%}
  {%- endfor -%}
{%- endif -%}
<button type="button"
        class="jj-watch-star jj-watch-star--{{ corner | default: 'tl' }}{% if is_watched %} jj-watch-btn--active{% endif %}"
        data-product-id="{{ product.id }}"
        data-watch
        {%- unless customer %} data-guest="true"{% endunless %}
        aria-pressed="{% if is_watched %}true{% else %}false{% endif %}"
        aria-label="{% if is_watched %}Remove from watchlist{% else %}Add to watchlist{% endif %}"
        title="{% if is_watched %}Remove from watchlist{% else %}Add to watchlist{% endif %}">
  <span class="jj-watch-btn__glyph" aria-hidden="true">{% if is_watched %}&#9733;{% else %}&#9734;{% endif %}</span>
</button>
